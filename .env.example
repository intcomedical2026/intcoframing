NEXT_PUBLIC_SANITY_PROJECT_ID=o10sbz2i
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-20
NEXT_PUBLIC_SITE_URL=https://www.intcoframing-us.com

# Required only when importing seed content into Sanity.
SANITY_API_TOKEN=
SANITY_IMPORT_DATASET=staging
SANITY_UPLOAD_ASSETS=false

# Production import has an extra safety gate. Set this only for the final production import.
SANITY_ALLOW_PRODUCTION_IMPORT=false

# Optional but recommended when the Sanity dataset is private.
# Use a Viewer token. This is server-only and should not be NEXT_PUBLIC.
SANITY_API_READ_TOKEN=
